# ===============================
# OpenClaw AutoPlatform .env 模板
# 首次使用建议：
# 1) cp .env.example .env
# 2) 按注释填写必填项
# 3) 运行: python3 scripts/internal/check_env.py
# ===============================

# 微信公众号（必填）
# 参数获取入口：https://developers.weixin.qq.com/platform
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_AUTHOR=W 小龙虾

# 飞书多维表格（必填）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_INSPIRATION_TABLE=01_内容灵感库 (OpenClaw)
FEISHU_PIPELINE_TABLE=02_自动化发布队列 (OpenClaw)
FEISHU_PUBLISH_LOG_TABLE=发布记录
FEISHU_ADMIN_USER_ID=

# ---------------------------------
# 模型配置（推荐 auto 双模式）
# auto: 优先 OpenClaw 代理，缺失时回退独立模型
# ---------------------------------
OPENCLAW_MODEL_PROVIDER=auto
OPENCLAW_PIPELINE_MODEL=auto
OPENCLAW_PIPELINE_ROLE=tech_expert
OPENCLAW_MODEL=auto
OPENCLAW_ROLE=tech_expert

# OpenClaw 代理（可选，走 OpenClaw 对话代理时填写）
# 支持别名：OPENCLAW_ENDPOINT / OPENCLAW_API_KEY
OPENCLAW_PROXY_ENDPOINT=
OPENCLAW_PROXY_API_KEY=
OPENCLAW_PROXY_MODEL=

# 独立模型回退（可选）
OPENCLAW_INDEPENDENT_MODEL=kimi-k2.5

# OpenAI 兼容（可选）
LLM_API_KEY=
LLM_ENDPOINT=
LLM_MODEL=

# Kimi（可选）
KIMI_API_KEY=
KIMI_ENDPOINT=https://api.moonshot.cn/v1
KIMI_MODEL_ID=kimi-k2.5

# 阿里百炼（可选）
BAILIAN_API_KEY=
BAILIAN_ENDPOINT=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_MODEL_ID=qwen3.5-plus

# 智谱（可选）
ZHIPU_API_KEY=
ZHIPU_ENDPOINT=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL_ID=glm-5

# MiniMax（可选）
MINIMAX_API_KEY=
MINIMAX_ENDPOINT=https://api.minimax.chat/v1
MINIMAX_MODEL_ID=MiniMax-M2.5

# 火山方舟（可选，文本改写）
VOLC_ARK_API_KEY=
VOLC_ARK_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
VOLC_ARK_MODEL_ID=doubao-seed-2-0-pro-260215

# 封面生图路由（可选）
# auto: 优先方舟生图，失败回退即梦
# ark: 仅方舟
# jimeng: 仅即梦
COVER_IMAGE_PROVIDER=auto

# 方舟生图（可选，OpenAI 兼容 images/generations）
ARK_IMAGE_API_KEY=
ARK_IMAGE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
# 若你有完整图片生成地址可直接填（优先级高于 ARK_IMAGE_ENDPOINT）
ARK_IMAGE_GENERATE_ENDPOINT=
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
# 可选：doubao-seedream-4-5-251128
ARK_IMAGE_SIZE=1280x720
# 常见值: b64_json / url
ARK_IMAGE_RESPONSE_FORMAT=b64_json

# 即梦生图（可选，作为方舟失败回退）
VOLCENGINE_AK=
VOLCENGINE_SK=
DEFAULT_COVER_URL=

# OpenClaw 运行优化（推荐）
OPENCLAW_NON_INTERACTIVE=1
OPENCLAW_AUTO_INSTALL=0
OPENCLAW_PIPELINE_BATCH_SIZE=3
OPENCLAW_SCHEMA_CHECK_ENABLED=1
OPENCLAW_SCHEMA_CHECK_INTERVAL_SEC=21600

# 广告位（可选）
WECHAT_AD_ENABLED=0
WECHAT_AD_POSITION=bottom
WECHAT_AD_TITLE=推广信息
WECHAT_AD_TEXT=
WECHAT_AD_LINK_TEXT=
WECHAT_AD_LINK_URL=
WECHAT_AD_IMAGE_PATH=
WECHAT_AD_IMAGE_URL=
WECHAT_AD_IMAGE_LINK_URL=
